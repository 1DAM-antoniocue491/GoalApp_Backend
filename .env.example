# ============================================================
# CONFIGURACIÓN DE LA BASE DE DATOS
# ============================================================
DATABASE_URL=postgresql+psycopg2://usuario:password@localhost:5432/futbol_app
DATABASE_ECHO=True

# ============================================================
# CONFIGURACIÓN DE SEGURIDAD JWT
# ============================================================
# Generar clave segura con: python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=tu_clave_secreta_aqui_cambiar
ALGORITHM=HS256
# 43200 minutos = 30 días (sesión persistente hasta logout manual)
ACCESS_TOKEN_EXPIRE_MINUTES=43200

# ============================================================
# CONFIGURACIÓN DE LA APLICACIÓN
# ============================================================
APP_NAME=Liga Amateur App
API_VERSION=v1
ENVIRONMENT=development
PORT=8000
HOST=0.0.0.0      # Cuando pase a producción se debe de poner la ip del servidor

# ============================================================
# CONFIGURACIÓN DE CORS
# ============================================================
# Orígenes permitidos para CORS (separados por comas, sin espacios)
# IMPORTANTE: En producción, incluir TODOS los orígenes del frontend
# Ejemplos:
#   - Desarrollo local: http://localhost:5173,http://localhost:3000
#   - Con frontend desplegado: http://localhost:5173,https://tu-frontend.vercel.app
#   - Con móvil: http://localhost:19006,http://localhost:8081
# Para Render: Asegúrate de configurar esta variable en el dashboard de Render
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost:19006,http://localhost:8081,http://127.0.0.1:5173,http://127.0.0.1:3000

# ============================================================
# CONFIGURACIÓN DE LOGGING
# ============================================================
LOG_LEVEL=INFO

# ============================================================
# CONFIGURACIÓN DE EMAIL (SMTP)
# ============================================================
# Servidor SMTP para envío de emails (ej: smtp.gmail.com para Gmail)
SMTP_HOST=smtp.gmail.com
# Puerto SMTP (587 para TLS, 465 para SSL)
SMTP_PORT=465
# Usuario del servidor SMTP (tu email)
SMTP_USER=tu_email@gmail.com
# Contraseña del servidor SMTP
# Para Gmail: usar App Password generada en https://myaccount.google.com/apppasswords
SMTP_PASSWORD=tu_app_password
# Usar SSL puro (True para puerto 465, False para puerto 587)
SMTP_USE_SSL=True
# Email remitente (normalmente el mismo que SMTP_USER)
EMAIL_FROM=tu_email@gmail.com
# URL del frontend para generar enlaces de recuperación/invitación
FRONTEND_URL=http://localhost:5173
# Tiempo de expiración del token de recuperación en minutos
RESET_TOKEN_EXPIRE_MINUTES=30